---
// Primary nav: pill with brand + WhatsApp on left, links + hamburger on right.
// Mobile toggle is wired up by the inline script at the bottom of this component.
---
<nav class="nav" aria-label="Primary">
  <div class="brand-group">
    <div class="brand"><span class="dot"></span>DIVYANSH&nbsp;SOOD</div>
    <a class="cta cta-wa" href="https://wa.me/919816091875?text=Hi%20Divyansh,%20I%20want%20a%20website%20for%20my%20business." target="_blank" rel="noopener" data-track="nav-whatsapp">
      <svg viewBox="0 0 32 32" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M16 .395c-8.836 0-16 7.164-16 16 0 2.823.738 5.583 2.137 8.011L0 32l7.83-2.057a15.92 15.92 0 008.17 2.247c8.836 0 16-7.164 16-16s-7.164-15.795-16-15.795zm7.27 19.366c-.397-.198-2.348-1.158-2.713-1.29-.365-.132-.629-.198-.893.198-.265.397-1.024 1.29-1.256 1.555-.232.265-.464.298-.86.099-.397-.198-1.677-.617-3.193-1.969-1.18-1.052-1.978-2.353-2.21-2.75-.232-.397-.025-.611.174-.808.179-.178.397-.464.595-.695.198-.232.265-.397.397-.661.132-.265.066-.496-.033-.695-.099-.198-.893-2.155-1.224-2.948-.322-.774-.65-.669-.893-.682a16.65 16.65 0 00-.762-.014c-.265 0-.695.099-1.058.496-.365.397-1.388 1.357-1.388 3.31s1.421 3.842 1.62 4.107c.198.265 2.798 4.272 6.776 5.99.946.408 1.685.652 2.262.835.951.302 1.815.26 2.498.158.762-.114 2.348-.96 2.679-1.886.331-.927.331-1.722.232-1.886-.099-.165-.365-.265-.762-.464z"/></svg>
      <span class="cta-wa-label">WhatsApp</span>
    </a>
  </div>

  <div class="nav-menu" id="nav-menu">
    <a class="nav-link" href="/#work">Work</a>
    <a class="nav-link" href="/#engagements">Pricing</a>
    <a class="nav-link" href="/#stack">Stack</a>
    <a class="nav-link" href="/#notes">Reviews</a>
    <a class="nav-link" href="/#about">About</a>
  </div>

  <button class="nav-toggle" id="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="nav-menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<script is:inline>
(function () {
  var t = document.getElementById('nav-toggle');
  var m = document.getElementById('nav-menu');
  if (!t || !m) return;
  function close() {
    m.classList.remove('is-open');
    t.classList.remove('is-open');
    t.setAttribute('aria-expanded', 'false');
  }
  function open() {
    m.classList.add('is-open');
    t.classList.add('is-open');
    t.setAttribute('aria-expanded', 'true');
  }
  t.addEventListener('click', function (e) {
    e.stopPropagation();
    if (m.classList.contains('is-open')) close(); else open();
  });
  m.querySelectorAll('a').forEach(function (a) { a.addEventListener('click', close); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
  document.addEventListener('click', function (e) {
    if (!m.classList.contains('is-open')) return;
    if (m.contains(e.target) || t.contains(e.target)) return;
    close();
  });
  var lastY = window.scrollY;
  window.addEventListener('scroll', function () {
    if (m.classList.contains('is-open') && Math.abs(window.scrollY - lastY) > 40) close();
    lastY = window.scrollY;
  }, { passive: true });
})();
</script>
