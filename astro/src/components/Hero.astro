---
// Hero — claim, proof, action. data-reveal hooks are read by interactions.js.
---
<header class="hero" id="top">
  <div class="hero-aura" data-parallax="0.18"></div>
  <div class="wrap">
    <div class="hero-eyebrow t-meta" data-reveal>
      <span class="eyebrow-dot"></span>
      <span><span class="eyebrow-mobile-hide">Solo studio · </span>Built in the Himalayas, for the Himalayas<span class="eyebrow-mobile-hide"> · 8 live clients</span></span>
    </div>

    <h1 class="t-mega reveal-lines">
      <span class="line"><span class="line-inner">Websites that</span></span>
      <span class="line"><span class="line-inner"><span class="accent-word">earn,</span> for you.</span></span>
    </h1>

    <div class="hero-sub">
      <div class="hero-pitch" data-reveal>
        <p class="caption">For Indian businesses with no website — or one that's broken. Custom-coded, mobile-designed, live in <strong>14 days</strong>. From <strong>₹7,000</strong>.</p>
        <ul class="hero-bullets">
          <li><span class="bdot"></span>Custom code, not Wix or theme bloat</li>
          <li><span class="bdot"></span>WhatsApp-first lead capture</li>
          <li><span class="bdot"></span>GST invoice · 50% advance · Day-5 refund</li>
        </ul>
      </div>
      <div class="hero-actions" data-reveal data-reveal-delay="100">
        <a href="https://wa.me/919816091875?text=Hi%20Divyansh,%20I%20want%20a%20website%20for%20my%20business." class="btn btn-primary" target="_blank" rel="noopener">WhatsApp now <span class="arrow">↗</span></a>
        <a href="#work" class="btn btn-ghost">See 8 live sites</a>
      </div>
    </div>

    <div class="hero-kpis" data-reveal data-reveal-delay="180">
      <div class="kpi"><div class="kpi-n">14<span>days</span></div><div class="kpi-l">Brief → live URL</div></div>
      <div class="kpi"><div class="kpi-n">₹7K<span>+</span></div><div class="kpi-l">Starting price</div></div>
      <div class="kpi"><div class="kpi-n">7<span>days</span></div><div class="kpi-l">Fastest delivery</div></div>
      <div class="kpi"><div class="kpi-n">600K<span>+</span></div><div class="kpi-l">Audience served</div></div>
    </div>
  </div>
</header>
