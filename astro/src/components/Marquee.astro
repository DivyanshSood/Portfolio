---
const items = [
  "CBSE School Portal",
  "D2C E-commerce",
  "600K Creator Storefront",
  "Himalayan Booking Platform",
  "Tour Operator CMS",
  "Solar Contractor Dashboard",
  "Taxi Operator Rebuild",
  "Brand + Razorpay Storefront",
  "AI Website Generator",
];
const sequence = [...items, "__live__", ...items, "__live__"];
---
<div class="marquee" aria-hidden="true">
  <div class="marquee-track">
    {sequence.map((item) => (
      item === "__live__" ? (
        <>
          <span class="marquee-item t-serif" style="font-style:italic;">Live in 14 days.</span>
          <span class="marquee-dot">●</span>
        </>
      ) : (
        <>
          <span class="marquee-item">{item}</span>
          <span class="marquee-dot">●</span>
        </>
      )
    ))}
  </div>
</div>
